# ── Database ──────────────────────────────────────
POSTGRES_DB=medha
POSTGRES_USER=medha
POSTGRES_PASSWORD=medha_secret
DATABASE_URL=postgresql+asyncpg://medha:medha_secret@postgres:5432/medha

# ── Redis ─────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── MinIO (object storage) ────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=medha-files
MINIO_SECURE=false

# ── Auth / JWT ────────────────────────────────────
SECRET_KEY=change_me_to_a_long_random_string_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── WhatsApp provider: baileys | meta ─────────────
WA_PROVIDER=baileys
BAILEYS_SERVICE_URL=http://baileys-service:3001

# ── Meta Cloud API (only needed if WA_PROVIDER=meta)
META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=
META_WEBHOOK_VERIFY_TOKEN=

# ── Email (IMAP/SMTP) ─────────────────────────────
EMAIL_HOST=
EMAIL_PORT=993
EMAIL_USE_SSL=true
EMAIL_USERNAME=
EMAIL_PASSWORD=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# ── Google OAuth (Gmail) ──────────────────────────
# console.cloud.google.com → APIs & Services → Credentials → Create OAuth 2.0 Client ID
# Authorized redirect URIs (add both):
#   http://localhost:3000/auth/google/callback        (login / sign-up)
#   http://localhost:3000/settings/email-callback     (connect Gmail in settings)
# Enable "Gmail API" in APIs & Services → Library
# Add your Google account as a test user on the OAuth consent screen (while in Testing mode)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Production (Vercel + droplet) — uncomment and use on the server .env:
# GOOGLE_REDIRECT_URI=https://medha-sync.vercel.app/settings/email-callback
# GOOGLE_AUTH_REDIRECT_URI=https://medha-sync.vercel.app/auth/google/callback
#
# Local dev:
GOOGLE_REDIRECT_URI=http://localhost:3000/settings/email-callback
GOOGLE_AUTH_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ── Microsoft OAuth (Outlook) ─────────────────────
# portal.azure.com → App registrations → New registration
# Redirect URI: http://localhost:3000/settings/email-callback (Web)
# API permissions: Mail.Read, offline_access, User.Read
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:3000/settings/email-callback

# ── Celery ────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Frontend ──────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change_me_to_a_long_random_string

# ── App ───────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=["http://localhost:3000"]
BACKEND_URL=http://backend:8000
PUBLIC_API_URL=http://localhost:8000
