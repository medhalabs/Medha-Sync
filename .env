# ── Database ──────────────────────────────────────
POSTGRES_DB=medha
POSTGRES_USER=medha
POSTGRES_PASSWORD=medha_secret
DATABASE_URL=postgresql+asyncpg://medha:medha_secret@postgres:5432/medha

# ── Redis ─────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── MinIO (object storage) ────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=medha-files
MINIO_SECURE=false

# ── Auth / JWT ────────────────────────────────────
SECRET_KEY=change_me_to_a_long_random_string_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── WhatsApp provider: baileys | meta ─────────────
WA_PROVIDER=baileys
BAILEYS_SERVICE_URL=http://baileys-service:3001

# ── Meta Cloud API (only needed if WA_PROVIDER=meta)
META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=
META_WEBHOOK_VERIFY_TOKEN=

# ── Email (IMAP/SMTP) ─────────────────────────────
EMAIL_HOST=
EMAIL_PORT=993
EMAIL_USE_SSL=true
EMAIL_USERNAME=
EMAIL_PASSWORD=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# ── Google OAuth (Gmail) ──────────────────────────
# 1. Go to console.cloud.google.com → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add http://localhost:3000/settings/email-callback to "Authorized redirect URIs"
# 4. Enable Gmail API in the project
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/settings/email-callback

# ── Microsoft OAuth (Outlook) ─────────────────────
# 1. Go to portal.azure.com → App registrations → New registration
# 2. Redirect URI: http://localhost:3000/settings/email-callback (Web)
# 3. Under "API permissions" add: Mail.Read, offline_access, User.Read
# 4. Create a client secret under "Certificates & secrets"
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:3000/settings/email-callback

# ── Celery ────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Frontend ──────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change_me_to_a_long_random_string

# ── App ───────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=["http://localhost:3000"]
BACKEND_URL=http://backend:8000
